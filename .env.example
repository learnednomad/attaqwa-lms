# =============================================================================
# AttaqwaMasjid LMS - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Generate secrets with:
#   openssl rand -base64 32
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=           # REQUIRED - strong password for the database

# ---------------------------------------------------------------------------
# Strapi API Keys
# ---------------------------------------------------------------------------
APP_KEYS=                    # REQUIRED - comma-separated base64 keys (4 recommended)
API_TOKEN_SALT=              # REQUIRED - random 32-char string
ADMIN_JWT_SECRET=            # REQUIRED - random 32-char string
TRANSFER_TOKEN_SALT=         # REQUIRED - random 32-char string
ENCRYPTION_KEY=              # REQUIRED - random 32-char string
JWT_SECRET=                  # REQUIRED - random 32-char string
STRAPI_API_TOKEN=            # REQUIRED - API token created in Strapi admin UI

# ---------------------------------------------------------------------------
# BetterAuth (website authentication)
# ---------------------------------------------------------------------------
BETTER_AUTH_SECRET=          # REQUIRED - random 32-char string
BETTER_AUTH_BASE_URL=http://localhost:3001

# ---------------------------------------------------------------------------
# MinIO / S3 Object Storage
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=attaqwa
MINIO_ROOT_PASSWORD=         # REQUIRED - strong password for MinIO
S3_BUCKET=uploads-public
S3_REGION=us-east-1
S3_BASE_URL=http://localhost:9000/uploads-public  # Production: use public URL

# ---------------------------------------------------------------------------
# Public URLs (browser-facing — INLINED into the Next.js bundle at BUILD time)
# ---------------------------------------------------------------------------
# These must be set BEFORE `docker compose build website|admin` runs so they
# bake into the client JavaScript bundle. Setting them at runtime alone has
# no effect — the bundle would already contain the localhost fallbacks.
#
# In Coolify: configure these as build-time/build-args (or as plain env vars
# if Coolify automatically forwards them; check the build logs to confirm).
#
# Production examples:
#   NEXT_PUBLIC_API_URL=https://attaqwa-api.learnednomad.com
#   NEXT_PUBLIC_AUTH_URL=https://attaqwa.learnednomad.com
#   NEXT_PUBLIC_ADMIN_URL=https://attaqwa.learnednomad.com
NEXT_PUBLIC_API_URL=http://localhost:1337
NEXT_PUBLIC_AUTH_URL=http://localhost:3001
NEXT_PUBLIC_ADMIN_URL=http://localhost:3000
# NEXT_PUBLIC_SUNNAH_API_KEY=         # Optional: sunnah.com Hadith API key

# ---------------------------------------------------------------------------
# Email notifications (Strapi nodemailer plugin)
# ---------------------------------------------------------------------------
# Required for the contact form and Ask-an-Imam form to deliver notifications.
# Without these set, submissions still persist to Strapi admin, but no email
# is sent. Works with any SMTP provider:
#
#   Resend:    SMTP_HOST=smtp.resend.com  SMTP_PORT=465  SMTP_SECURE=true
#              SMTP_USER=resend           SMTP_PASS=re_xxxxxxxxxxxxxxxx
#   SendGrid:  SMTP_HOST=smtp.sendgrid.net SMTP_PORT=465 SMTP_SECURE=true
#              SMTP_USER=apikey           SMTP_PASS=SG.xxxxxxxxxxxxxxxx
#   Postmark:  SMTP_HOST=smtp.postmarkapp.com SMTP_PORT=587 SMTP_SECURE=false
#              SMTP_USER=<server-token>   SMTP_PASS=<server-token>
#
# EMAIL_FROM must be a verified sender on your provider account.
# EMAIL_NOTIFY_TO is the inbox that receives all inquiries (contact + legal).
# LEGAL_INQUIRY_SISTERS_NOTIFY_TO is optional — defaults to EMAIL_NOTIFY_TO.
#
# SMTP_HOST=                 # e.g. smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=                 # provider-specific
# SMTP_PASS=                 # provider API key
# EMAIL_FROM=noreply@masjidattaqwaatlanta.org
# EMAIL_REPLY_TO=almaad2674@gmail.com
# EMAIL_NOTIFY_TO=almaad2674@gmail.com
# CONTACT_INQUIRY_NOTIFY_TO=  # Optional override for contact inquiries only
# LEGAL_INQUIRY_NOTIFY_TO=    # Optional override for ask-an-imam (general)
# LEGAL_INQUIRY_SISTERS_NOTIFY_TO=  # Optional override for sisters' questions

# ---------------------------------------------------------------------------
# Production only (docker-compose.prod.yml)
# ---------------------------------------------------------------------------
# DOMAIN=attaqwa.org         # Caddy auto-TLS domain
# REDIS_PASSWORD=            # REQUIRED in production
# CADDY_HTTP_PORT=80
# CADDY_HTTPS_PORT=443

# ---------------------------------------------------------------------------
# Ollama AI (optional, use --profile ai)
# ---------------------------------------------------------------------------
# OLLAMA_ENABLED=false
# OLLAMA_MODEL=mistral:7b-instruct-q4_K_M
# OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_TIMEOUT_MS=120000
# OLLAMA_MAX_PARALLEL=2
# EMBEDDING_DIMENSION=768

# ---------------------------------------------------------------------------
# Monitoring (docker-compose.monitoring.yml)
# ---------------------------------------------------------------------------
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=           # Change from default
# GRAFANA_PORT=3300
# PROMETHEUS_PORT=9090
