# =============================================================================
# AttaqwaMasjid LMS - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Generate secrets with: openssl rand -base64 32
# =============================================================================

# ── Core Database ────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me

# ── Strapi Secrets (generate each with: openssl rand -base64 32) ─────────────
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
ENCRYPTION_KEY=
JWT_SECRET=

# ── BetterAuth (website authentication) ──────────────────────────────────────
BETTER_AUTH_SECRET=
BETTER_AUTH_BASE_URL=http://localhost:3003

# ── MinIO / S3 Storage ──────────────────────────────────────────────────────
MINIO_ROOT_USER=attaqwa
MINIO_ROOT_PASSWORD=change-me
S3_BUCKET=uploads-public
S3_REGION=us-east-1
# Dev: http://localhost:9000/uploads-public
# Prod: https://yourdomain.com/s3/uploads-public
S3_BASE_URL=http://localhost:9000/uploads-public

# ── Admin Portal ─────────────────────────────────────────────────────────────
# Create via Strapi Admin Panel: Settings > API Tokens > Create (Full Access)
STRAPI_API_TOKEN=

# ── Production Only ──────────────────────────────────────────────────────────
# DOMAIN=yourdomain.com
# REDIS_PASSWORD=change-me
# DATABASE_SSL=true
# NODE_ENV=production

# ── Islamic Content APIs (optional) ──────────────────────────────────────────
# HADITH_API_KEY=
# NEXT_PUBLIC_PRAYER_API_KEY=
# NEXT_PUBLIC_SUNNAH_API_KEY=

# ── AI / Ollama (optional, use --profile ai) ─────────────────────────────────
# OLLAMA_ENABLED=false
# OLLAMA_MODEL=mistral:7b-instruct-q4_K_M
# OLLAMA_EMBED_MODEL=nomic-embed-text
