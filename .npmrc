# Multi-platform install support so containerized linux-musl-arm64 deployments
# resolve native binaries (sharp, lightningcss, etc.) when host is darwin-arm64.
supported-architectures[os][]=current
supported-architectures[os][]=linux
supported-architectures[cpu][]=current
supported-architectures[cpu][]=arm64
supported-architectures[cpu][]=x64
supported-architectures[libc][]=current
supported-architectures[libc][]=glibc
supported-architectures[libc][]=musl
